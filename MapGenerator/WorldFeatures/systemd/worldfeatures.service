[Unit]
Description=WorldFeatures Worker
After=local-fs.target

[Service]
Type=oneshot
EnvironmentFile=%h/Code/RTSColonyTerrainGenerator/.env
WorkingDirectory=%h/Code/RTSColonyTerrainGenerator/MapGenerator/WorldFeatures
ExecStart=%h/Code/RTSColonyTerrainGenerator/MapGenerator/WorldFeatures/bin/consume_worldfeatures_job.sh

ReadWritePaths=%h/Code/RTSColonyTerrainGenerator/logs
ReadWritePaths=%h/Code/RTSColonyTerrainGenerator/MapGenerator/WorldFeatures

Restart=no

[Install]
WantedBy=default.target
