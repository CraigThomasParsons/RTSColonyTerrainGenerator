{
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "source.php keyword.control, source.php storage.type, source.php storage.modifier, source.php keyword.operator",
                "settings": {
                    "foreground": "#96CBFE"
                }
            },
            {
                "scope": "source.php entity.name.function, source.php support.function",
                "settings": {
                    "foreground": "#FFD2A7"
                }
            },
            {
                "scope": "source.php string, source.php string.quoted",
                "settings": {
                    "foreground": "#A8FF60"
                }
            },
            {
                "scope": "source.php variable, source.php variable.other",
                "settings": {
                    "foreground": "#C6C5FE"
                }
            },
            {
                "scope": "source.php comment, source.php comment.block, source.php comment.line",
                "settings": {
                    "foreground": "#7C7C7C",
                    "fontStyle": "italic"
                }
            },
            {
                "scope": "source.php entity.name.type, source.php support.class, source.php entity.other.inherited-class",
                "settings": {
                    "foreground": "#FFFFB6"
                }
            },
            {
                "scope": "source.php constant, source.php constant.language, source.php constant.numeric",
                "settings": {
                    "foreground": "#99CC99"
                }
            },
            {
                "scope": "source.php constant.numeric, source.php constant.language",
                "settings": {
                    "foreground": "#FF73FD"
                }
            },
            {
                "scope": "source.php punctuation.section.embedded.begin.php, source.php punctuation.section.embedded.end.php",
                "settings": {
                    "foreground": "#CC6666"
                }
            }
        ]
    }
}